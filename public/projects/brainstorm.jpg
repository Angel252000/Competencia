<svg xmlns="http://www.w3.org/2000/svg" width="640" height="360" viewBox="0 0 640 360">
  <rect width="640" height="360" fill="#0f172a"/>
  <rect x="0" y="0" width="640" height="360" fill="url(#g)" opacity="0.3"/>
  <defs>
    <linearGradient id="g" x1="0" y1="0" x2="640" y2="360">
      <stop offset="0%" stop-color="#38bdf8" stop-opacity="0.3"/>
      <stop offset="100%" stop-color="#38bdf8" stop-opacity="0"/>
    </linearGradient>
    <linearGradient id="t" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="white"/>
      <stop offset="100%" stop-color="#38bdf8"/>
    </linearGradient>
  </defs>
  <text x="320" y="150" text-anchor="middle" dominant-baseline="middle" font-size="64">🧠</text>
  <text x="320" y="220" text-anchor="middle" dominant-baseline="middle" font-family="sans-serif" font-size="18" font-weight="bold" fill="white" opacity="0.8">urainstorm</text>
</svg>
